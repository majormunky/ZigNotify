# munknotify configuration

# Notification size
width = 300
height = 100
margin = 10

# Timeout in milliseconds (-1 uses default_timeout, 0 never expires)
default_timeout = 5000

# Font sizes
font_size_summary = 16.0
font_size_body = 16.0
font_size_app_name = 10.0

# radius or rounded corners
corner_radius = 12.0

# Position: top_right, top_left, bottom_right, bottom_left
position = top_right

# Colors in r,g,b,a format (0.0 - 1.0)
background_color = 0.18, 0.18, 0.18, 1.0
low_color = 0.5, 0.5, 0.5, 1.0
normal_color = 0.27, 0.52, 0.95, 1.0
critical_color = 0.9, 0.2, 0.2, 1.0
